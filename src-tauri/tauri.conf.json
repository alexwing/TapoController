{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TapoController",
  "version": "0.1.0",
  "identifier": "dev.tapocontroller.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TapoController",
        "width": 460,
        "height": 720,
        "resizable": true,
        "minWidth": 380,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
